{% doc %}
  @prompt
    Create a tabbed product information section with three tabs: "Details & Description", "Washcare", and "Shipping".
    
    Design requirements:
    - Clean tab navigation with an underline indicator on the active tab (not a filled background), tabs are left-aligned
    - Tab labels use a minimal, light font style
    - Content area below tabs has a subtle top border
    
    Tab 1 - "Details & Description" (dynamic):
    - Renders product.description using Liquid ({{ product.description }})
    - The description should support HTML formatting
    - No editable block needed — pulls directly from the product description
    
    Tab 2 - "Washcare" (editable via theme blocks):
    - Merchants can add multiple washcare instruction lines via repeatable blocks in the theme editor
    - Each block has a single text field for one instruction (e.g. "Reverse wash only", "No direct iron on print", "Steam iron recommended")
    - Displayed as a simple list
    
    Tab 3 - "Shipping" (editable via theme blocks):
    - Same repeatable block structure as Washcare
    - Each block has a single text field for one shipping info line (e.g. "Shipped within 24 hours", "Free delivery pan-india", "Dispatches next day")
    - Displayed as a simple list
    
    Implementation:
    - Use pure CSS for tab switching (no JavaScript) using radio input hack
    - Tabs should be fully responsive on mobile and desktop
    - Typography: small, clean sans-serif, consistent with a dark luxury fashion brand
    - Active tab underline should be dark/Black
    - Content padding should be comfortable but minimal
    - The section should be a standalone Shopify theme section with full schema support for the blocks
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-tabs-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    font-family: {{ settings.type_body_font.family }}, sans-serif;
    font-weight: {{ settings.type_body_font.weight }};
  }

  .ai-product-tabs__nav-{{ ai_gen_id }} {
    display: flex;
    gap: 32px;
    border-bottom: 1px solid {{ block.settings.border_color }};
    margin-bottom: 24px;
  }

  .ai-product-tabs__radio-{{ ai_gen_id }} {
    display: none;
  }

  .ai-product-tabs__label-{{ ai_gen_id }} {
    position: relative;
    padding: 12px 0;
    font-size: {{ block.settings.tab_font_size }}px;
    font-weight: {{ block.settings.tab_font_weight }};
    color: {{ block.settings.tab_color }};
    cursor: pointer;
    transition: color 0.3s ease;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    text-transform: {{ block.settings.tab_text_transform }};
    letter-spacing: {{ block.settings.tab_letter_spacing }}px;
  }

  .ai-product-tabs__label-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_active_color }};
  }

  .ai-product-tabs__radio-{{ ai_gen_id }}:checked + .ai-product-tabs__label-{{ ai_gen_id }} {
    color: {{ block.settings.tab_active_color }};
    border-bottom-color: {{ block.settings.tab_active_underline_color }};
  }

  .ai-product-tabs__content-{{ ai_gen_id }} {
    display: none;
    padding-top: {{ block.settings.content_padding_top }}px;
    font-size: {{ block.settings.content_font_size }}px;
    line-height: {{ block.settings.content_line_height }};
    color: {{ block.settings.content_color }};
  }

  .ai-product-tabs__radio-{{ ai_gen_id }}:checked ~ .ai-product-tabs__content-{{ ai_gen_id }} {
    display: block;
  }

  .ai-product-tabs__description-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-product-tabs__description-{{ ai_gen_id }} p {
    margin: 0 0 16px 0;
  }

  .ai-product-tabs__description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-product-tabs__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-product-tabs__list-item-{{ ai_gen_id }} {
    padding: 8px 0;
    border-bottom: 1px solid {{ block.settings.list_divider_color }};
  }

  .ai-product-tabs__list-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-product-tabs__empty-state-{{ ai_gen_id }} {
    padding: 24px;
    text-align: center;
    color: {{ block.settings.empty_state_color }};
    font-style: italic;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-tabs__nav-{{ ai_gen_id }} {
      gap: 20px;
    }

    .ai-product-tabs__label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.tab_font_size }}px * 0.9);
      padding: 10px 0;
    }

    .ai-product-tabs__content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.content_font_size }}px * 0.95);
    }
  }
{% endstyle %}

<product-tabs-{{ ai_gen_id }} class="ai-product-tabs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-tabs__nav-{{ ai_gen_id }}">
    <input
      type="radio"
      name="ai-product-tabs-{{ ai_gen_id }}"
      id="ai-tab-details-{{ ai_gen_id }}"
      class="ai-product-tabs__radio-{{ ai_gen_id }}"
      checked
    >
    <label for="ai-tab-details-{{ ai_gen_id }}" class="ai-product-tabs__label-{{ ai_gen_id }}">
      {{ block.settings.tab_1_label }}
    </label>

    <input
      type="radio"
      name="ai-product-tabs-{{ ai_gen_id }}"
      id="ai-tab-washcare-{{ ai_gen_id }}"
      class="ai-product-tabs__radio-{{ ai_gen_id }}"
    >
    <label for="ai-tab-washcare-{{ ai_gen_id }}" class="ai-product-tabs__label-{{ ai_gen_id }}">
      {{ block.settings.tab_2_label }}
    </label>

    <input
      type="radio"
      name="ai-product-tabs-{{ ai_gen_id }}"
      id="ai-tab-shipping-{{ ai_gen_id }}"
      class="ai-product-tabs__radio-{{ ai_gen_id }}"
    >
    <label for="ai-tab-shipping-{{ ai_gen_id }}" class="ai-product-tabs__label-{{ ai_gen_id }}">
      {{ block.settings.tab_3_label }}
    </label>
  </div>

  <div class="ai-product-tabs__content-{{ ai_gen_id }} ai-product-tabs__content-details-{{ ai_gen_id }}">
    {% if product.description != blank %}
      <div class="ai-product-tabs__description-{{ ai_gen_id }}">
        {{ product.description }}
      </div>
    {% else %}
      <div class="ai-product-tabs__empty-state-{{ ai_gen_id }}">
        No product description available
      </div>
    {% endif %}
  </div>

  <div class="ai-product-tabs__content-{{ ai_gen_id }} ai-product-tabs__content-washcare-{{ ai_gen_id }}">
    {% assign washcare_lines = block.settings.washcare_content | newline_to_br | split: '<br />' %}
    {% if block.settings.washcare_content != blank %}
      <ul class="ai-product-tabs__list-{{ ai_gen_id }}">
        {% for line in washcare_lines %}
          {% assign trimmed_line = line | strip %}
          {% if trimmed_line != blank %}
            <li class="ai-product-tabs__list-item-{{ ai_gen_id }}">
              {{ trimmed_line }}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% else %}
      <div class="ai-product-tabs__empty-state-{{ ai_gen_id }}">
        Add washcare instructions in the theme editor
      </div>
    {% endif %}
  </div>

  <div class="ai-product-tabs__content-{{ ai_gen_id }} ai-product-tabs__content-shipping-{{ ai_gen_id }}">
    {% assign shipping_lines = block.settings.shipping_content | newline_to_br | split: '<br />' %}
    {% if block.settings.shipping_content != blank %}
      <ul class="ai-product-tabs__list-{{ ai_gen_id }}">
        {% for line in shipping_lines %}
          {% assign trimmed_line = line | strip %}
          {% if trimmed_line != blank %}
            <li class="ai-product-tabs__list-item-{{ ai_gen_id }}">
              {{ trimmed_line }}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% else %}
      <div class="ai-product-tabs__empty-state-{{ ai_gen_id }}">
        Add shipping information in the theme editor
      </div>
    {% endif %}
  </div>
</product-tabs-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductTabs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const radios = this.querySelectorAll('.ai-product-tabs__radio-{{ ai_gen_id }}');
        radios.forEach(radio => {
          radio.addEventListener('change', () => {
            if (radio.checked) {
              radio.setAttribute('aria-selected', 'true');
            }
          });
        });
      }
    }

    customElements.define('product-tabs-{{ ai_gen_id }}', ProductTabs{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product tabs",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Tab labels"
    },
    {
      "type": "text",
      "id": "tab_1_label",
      "label": "Tab 1 label",
      "default": "Details & Description"
    },
    {
      "type": "text",
      "id": "tab_2_label",
      "label": "Tab 2 label",
      "default": "Washcare"
    },
    {
      "type": "text",
      "id": "tab_3_label",
      "label": "Tab 3 label",
      "default": "Shipping"
    },
    {
      "type": "header",
      "content": "Tab 2 content"
    },
    {
      "type": "paragraph",
      "content": "Enter each washcare instruction on a new line"
    },
    {
      "type": "textarea",
      "id": "washcare_content",
      "label": "Washcare instructions"
    },
    {
      "type": "header",
      "content": "Tab 3 content"
    },
    {
      "type": "paragraph",
      "content": "Enter each shipping detail on a new line"
    },
    {
      "type": "textarea",
      "id": "shipping_content",
      "label": "Shipping information"
    },
    {
      "type": "header",
      "content": "Tab style"
    },
    {
      "type": "range",
      "id": "tab_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "select",
      "id": "tab_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "tab_text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "tab_letter_spacing",
      "min": 0,
      "max": 3,
      "step": 0.5,
      "unit": "px",
      "label": "Letter spacing",
      "default": 0
    },
    {
      "type": "color",
      "id": "tab_color",
      "label": "Tab color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "tab_active_color",
      "label": "Active tab color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "tab_active_underline_color",
      "label": "Active underline color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Content style"
    },
    {
      "type": "range",
      "id": "content_padding_top",
      "min": 12,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "content_font_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "range",
      "id": "content_line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.6
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "list_divider_color",
      "label": "List divider color",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "empty_state_color",
      "label": "Empty state color",
      "default": "#999999"
    }
  ],
  "presets": [
    {
      "name": "Product tabs"
    }
  ]
}
{% endschema %}
