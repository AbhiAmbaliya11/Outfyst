{% style %}
  .fitness-text-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.desktop_padding_top }}px 20px {{ section.settings.desktop_padding_bottom }}px;
    text-align: center;
  }

  .fitness-text-section-{{ section.id }} .fitness-small-text {
    color: {{ section.settings.small_text_color }};
    font-size: {{ section.settings.small_text_size }}px;
    letter-spacing: {{ section.settings.small_letter_spacing }}px;
    text-transform: uppercase;
    margin-bottom: {{ section.settings.small_text_spacing }}px;
    font-weight: {{ section.settings.small_text_weight }};
  }

  .fitness-text-section-{{ section.id }} .fitness-main-heading {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    font-size: {{ section.settings.heading_size }}px;
    line-height: {{ section.settings.heading_line_height }};
    font-weight: {{ section.settings.heading_weight }};
    text-transform: uppercase;
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
  }

  .fitness-text-section-{{ section.id }} .white-text {
    color: {{ section.settings.primary_text_color }};
    font-family: "Archivo Black", sans-serif;
  }

  .fitness-text-section-{{ section.id }} .red-text {
    color: {{ section.settings.highlight_text_color }};
    font-family: "Archivo Black", sans-serif;
  }

  @media screen and (max-width: 768px) {
    .fitness-text-section-{{ section.id }} {
      padding: {{ section.settings.mobile_padding_top }}px 15px {{ section.settings.mobile_padding_bottom }}px;
    }

    .fitness-text-section-{{ section.id }} .fitness-main-heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
      line-height: {{ section.settings.mobile_line_height }};
    }

    .fitness-text-section-{{ section.id }} .fitness-small-text {
      font-size: {{ section.settings.mobile_small_text_size }}px;
      letter-spacing: {{ section.settings.mobile_small_letter_spacing }}px;
    }
  }
  .fitness-text-section-template--20162184413320__custom_text_prwWzN{
    padding: 120px 20px !important;
  }
{% endstyle %}

<section class="fitness-text-section-{{ section.id }}">
  {% if section.settings.small_text != blank %}
    <div class="fitness-small-text">
      {{ section.settings.small_text }}
    </div>
  {% endif %}

  <h2 class="fitness-main-heading">
    <span class="white-text">{{ section.settings.line_1 }}</span><br>
    <span class="white-text">{{ section.settings.line_2_before }}</span>
    <span class="red-text">{{ section.settings.line_2_highlight }}</span><br>
    <span class="white-text">{{ section.settings.line_3_before }}</span>
    <span class="red-text">{{ section.settings.line_3_highlight }}</span>
  </h2>
</section>

