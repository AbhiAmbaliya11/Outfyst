<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link
  rel="stylesheet"
  href="{{ 'component-cart-notification.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}


<style>

  :root {
    --header-bg: #000000;
    --header-border: rgba(255, 255, 255, 0.08);
    --header-text: #ffffff;
    --header-height-desktop: 64px;
    --header-height-mobile: 56px;
    --nav-underline-duration: 200ms;
    --mobile-menu-duration: 300ms;
    --nav-active-color: #c8102e;
    --glass-bg: rgba(0, 0, 0, 0.58);
    --glass-blur: blur(20px) saturate(160%);
  }

  .header-OUTFYST {
    position: fixed;
    top : 30px;
    left: 0px;
    right: 0px;
    z-index: 55;
    height: 64px;
    background: rgba(18, 18, 18, 0.55);
    backdrop-filter: blur(24px) saturate(160%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: rgba(0, 0, 0, 0.18) 0px 8px 24px, rgba(255, 255, 255, 0.18) 0px 1px 0px inset;
  }

  @media screen and (max-width: 990px) {
  .header-OUTFYST {
    top: 0 !important;
    background: transparent !important;
    backdrop-filter: none !important;
    border-bottom: none !important;
    box-shadow: none !important;
  }
}

  /* ---- Reset Dawn header defaults ---- */
  .section-header {
    position: sticky !important;
    top: 0;
    z-index: 100;
    background: transparent !important;
    border-bottom: 0.5px solid transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    transition:
      background 0.4s ease,
      border-color 0.4s ease,
      backdrop-filter 0.4s ease,
      -webkit-backdrop-filter 0.4s ease;
  }

  /* ── GLASS STATE on scroll ── */
  .section-header.header-scrolled {
    background: var(--glass-bg) !important;
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom-color: var(--header-border);
  }

  /* Dawn sticky classes also get glass */
  .section-header.shopify-section-header-sticky {
    background: var(--glass-bg) !important;
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom-color: var(--header-border);
  }

  .outfyst-header {
    max-width: 1600px;
    margin: 0px auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height-desktop);
    padding: 0 32px;
    background: transparent;
    position: relative;
  }

  /* ---- LEFT: Logo (desktop only) ---- */
  .outfyst-header__logo {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    text-decoration: none;
    z-index: 2;
  }

  .outfyst-header__logo-img {
    height: 28px;
    width: auto;
    display: block;
  }

  .outfyst-header__logo-text {
    font-family: "Archivo Black", sans-serif;
    font-size: 20px;
    color: rgb(255, 255, 255);
    letter-spacing: -0.01em;
    color: var(--header-text);
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
  }

  /* ---- CENTER: Navigation ---- */
  .outfyst-header__nav {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .outfyst-header__nav-link {
    text-decoration: none;
    font-family: Manrope, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.85);
    text-transform: uppercase;
    padding: 10px 4px;
    cursor: pointer;
    position: relative;
    border-bottom: 2px solid transparent;
    transition: 200ms;
  }
.outfyst-header__nav-link:hover {
  border-bottom: 2px solid rgb(139, 15, 26);
  transition: 200ms;
}



  /* ---- RIGHT: Icons (untouched Dawn logic) ---- */
  .header__icons {
    display: flex;
    gap: 18px;
    align-items: center;
  }

  .header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--header-text) !important;
    background: transparent !important;
    border: none !important;
    position: relative;
  }

  .header__icon svg,
  .header__icon .svg-wrapper svg,
  .header__icon .svg-wrapper {
    color: var(--header-text) !important;
    fill: none;
    stroke: var(--header-text) !important;
  }

  .cart-count-bubble {
    background: var(--header-text) !important;
    color: var(--header-bg) !important;
    font-size: 9px;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 4px;
    right: 4px;
  }

  .desktop-localization-wrapper {
    display: flex;
    align-items: center;
  }

  /* ============================================================
     MOBILE HAMBURGER — "+ OUTFYST" PILL BUTTON
     ============================================================ */
  .outfyst-hamburger {
    position: absolute;
    top: 20px;
    left: 14px;
    z-index: 30;
    height: 42px;
    padding: 0px 16px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(18, 18, 18, 0.45);
    backdrop-filter: blur(22px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: rgba(0, 0, 0, 0.28) 0px 6px 18px, rgba(255, 255, 255, 0.22) 0px 1px 0px inset;
    cursor: pointer;
    color: #fff;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .outfyst-hamburger:active {
    background: rgba(255, 255, 255, 0.22);
    transform: scale(0.97);
  }

  .outfyst-hamburger__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    position: relative;
    transition: transform var(--mobile-menu-duration) ease;
  }

  .outfyst-hamburger__icon::before,
  .outfyst-hamburger__icon::after {
    content: '';
    position: absolute;
    background: #fff;
    border-radius: 1px;
    transition:
      transform var(--mobile-menu-duration) ease,
      opacity var(--mobile-menu-duration) ease;
  }
  .outfyst-hamburger__icon::before {
    width: 11px;
    height: 1.2px;
  }
  .outfyst-hamburger__icon::after {
    width: 1.2px;
    height: 11px;
  }

  .outfyst-hamburger.is-open .outfyst-hamburger__icon {
    transform: rotate(45deg);
  }

  .outfyst-hamburger__label {
    display: block;
    line-height: 1;
  }


  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media screen and (max-width: 990px) {
    .outfyst-header {
      height: var(--header-height-mobile);
      padding: 0 16px;
    }

    .outfyst-header__nav {
      display: none;
    }


    /* ── Remove center logo on mobile ── */
    .outfyst-header__logo {
      display: none !important;
    }

    .header__icon--search-modal,
    .header__icon--account {
      display: none !important;
    }

    
  }

  @media screen and (min-width: 991px) {
    .outfyst-hamburger,
    .outfyst-mobile-menu {
      display: none !important;
    }

    .small-hide {
      display: flex;
    }
  }

  /* Hide Dawn's original header layout */
  .header.header--left,
  .header.header--center,
  .header.header--top-center {
    display: none;
  }

/* SVG base */
.icon-wishlist {
  width: 20px;
  height: 20px;
  display: block;
}

/* Path styling (light / normal look) */
.icon-wishlist path {
  stroke: rgba(255, 255, 255, 0.85);
  stroke-width: 1.4;
  fill: none;
  stroke-linejoin: round;
}

/* Hover effect */
.header__icon--wishlist:hover .icon-wishlist path {
  stroke: #ffffff;
}

.header__icon--cart {
  margin-top: 6px !important;
}

/* ── MOBILE ICON PILLS (separate structure, desktop hidden) ── */
.outfyst-mobile-icons {
  display: none;
}

@media screen and (max-width: 990px) {
  .outfyst-mobile-icons {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }

  .outfyst-mobile-icon-pill {
    width: 42px;
    height: 42px;
    top: 14px;
    position: relative;
    border-radius: 999px;
    cursor: pointer;
    padding: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(18, 18, 18, 0.45);
    backdrop-filter: blur(22px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: rgba(0, 0, 0, 0.28) 0px 6px 18px, rgba(255, 255, 255, 0.22) 0px 1px 0px inset;
  }

  .outfyst-mobile-icon-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    background: #c0392b;
    color: #fff;
    font-family: 'Manrope', sans-serif;
    font-size: 9px;
    font-weight: 700;
    min-width: 15px;
    height: 15px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    padding: 0 2px;
  }
.header__icon--cart {
  margin-top: 0px !important;
  margin-right: 10px;
  
}


}


/* Drawer slide-in from left */
.outfyst-mobile-menu {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: min(320px, 85vw);
  background: rgba(10, 10, 10, 0.97);
  backdrop-filter: blur(24px) saturate(140%);
  -webkit-backdrop-filter: blur(24px) saturate(140%);
  border-right: 1px solid rgba(255, 255, 255, 0.07);
  z-index: 200;
  padding: 24px 28px 40px;
  overflow-y: auto;
  transform: translateX(-100%);
  transition: transform 350ms cubic-bezier(0.4, 0, 0.2, 1);
  visibility: hidden;
}

.outfyst-mobile-menu.is-open {
  transform: translateX(0);
  visibility: visible;
}

/* Backdrop overlay */
.outfyst-menu-backdrop {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 199;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  opacity: 0;
  transition: opacity 350ms ease;
}

.outfyst-menu-backdrop.is-open {
  display: block;
  opacity: 1;
}

/* Close button */
.outfyst-mobile-menu__close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.7);
  cursor: pointer;
  margin-left: auto;
  transition: background 0.2s ease, color 0.2s ease;
}

.outfyst-mobile-menu__close:hover {
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
}

/* ── DRAWER NAV LIST ─────────────────────────────────── */
.outfyst-menu__list {
  list-style: none;
  margin: 0;
  padding: 0;
}

/* ── PARENT ITEM ─────────────────────────────────────── */
.outfyst-menu__item {
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.outfyst-menu__item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.outfyst-menu__link {
  display: block;
  padding: 15px 0;
  font-family: 'Manrope', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.9);
  text-decoration: none;
  flex: 1;
  transition: color 0.2s ease;
}

.outfyst-menu__link:hover {
  color: #ffffff;
}

/* ── TOGGLE BUTTON (+/-) ─────────────────────────────── */
.outfyst-menu__toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 4px;
  color: rgba(255, 255, 255, 0.5);
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease;
}

.outfyst-menu__toggle:hover {
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
}

.outfyst-menu__toggle .icon-minus { display: none; }
.outfyst-menu__toggle[aria-expanded="true"] .icon-plus  { display: none; }
.outfyst-menu__toggle[aria-expanded="true"] .icon-minus { display: block; }

/* ── CHILD LIST ──────────────────────────────────────── */
.outfyst-menu__child-list {
  list-style: none;
  margin: 0;
  padding: 0 0 8px 14px;
  border-left: 1px solid rgba(255, 255, 255, 0.08);
  margin-left: 4px;
  display: none;
}

.outfyst-menu__item.is-open > .outfyst-menu__child-list {
  display: block;
}

.outfyst-menu__child-item {
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.outfyst-menu__link--child {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: rgba(255, 255, 255, 0.6);
  padding: 12px 0;
}

.outfyst-menu__link--child:hover {
  color: rgba(255, 255, 255, 0.9);
}

/* ── SUBCHILD LIST ───────────────────────────────────── */
.outfyst-menu__subchild-list {
  list-style: none;
  margin: 0;
  padding: 0 0 6px 12px;
  border-left: 1px solid rgba(255, 255, 255, 0.05);
  margin-left: 4px;
  display: none;
}

.outfyst-menu__child-item.is-open > .outfyst-menu__subchild-list {
  display: block;
}

.outfyst-menu__subchild-item {
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
}

.outfyst-menu__link--subchild {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.07em;
  color: rgba(255, 255, 255, 0.38);
  padding: 10px 0;
  text-transform: uppercase;
}

.brand-name {
    text-decoration: none;
}
.outfyst-menu__link--subchild:hover {
  color: rgba(255, 255, 255, 0.65);
}

.outfyst-mobile-menu__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28px;
}



/* ── MOBILE BOTTOM NAV ───────────────────────────────────────── */
.outfyst-bottom-nav {
  display: none;
}

@media screen and (max-width: 990px) {
  .outfyst-bottom-nav {
    display: block;
    position: fixed;
    bottom: 20px;
    left: 14px;
    right: 14px;
    z-index: 40;
    transform: translateY(0px);
    transition: transform 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
    pointer-events: auto;
  }

  .outfyst-bottom-nav__inner {
    position: relative;
    height: 66px;
  }

  /* Left pill — Home, Account, Search */
  .outfyst-bottom-nav__pill {
    position: absolute;
    inset: 0 56px 0 0;
    height: 66px;
    border-radius: 999px;
    background: rgba(18, 18, 18, 0.55);
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: rgba(0, 0, 0, 0.35) 0px 8px 24px, rgba(255, 255, 255, 0.18) 0px 1px 0px inset;
    display: flex;
    align-items: center;
    padding: 0 12px 0 18px;
    justify-content: space-around;
  }

  /* Each icon button */
  .outfyst-bottom-nav__btn {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    color: rgba(245, 242, 236, 0.7);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .outfyst-bottom-nav__btn:hover {
    color: rgba(245, 242, 236, 1);
  }

  /* Right: Cart metallic pill button */
  .outfyst-bottom-nav-stories-popup {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 60px;
    height: 60px;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    padding: 0;
    background: radial-gradient(circle at 30% 25%, rgb(255, 255, 255) 0%, rgb(232, 232, 232) 18%, transparent 40%),
                linear-gradient(160deg, rgb(242, 242, 242) 0%, rgb(201, 201, 201) 45%, rgb(111, 111, 111) 100%);
    box-shadow: rgba(0, 0, 0, 0.4) 0px 8px 20px,
                rgba(255, 255, 255, 0.95) 0px 1px 0px inset,
                rgba(0, 0, 0, 0.28) 0px -10px 18px inset;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #111;
  }

  .outfyst-bottom-nav-stories-popup svg {
    width: 22px;
    height: 22px;
    stroke: #111;
    fill: none;
  }

}
@media screen and (max-width: 990px) {

  /* Specific elements hide karo */
  .header__icons .desktop-localization-wrapper,
  .header__icons .header__icon--account,
  .header__icons .header__icon--cart,
  .header__icons [class*="header__icon"] {
    display: none !important;
  }
}
/* ── PAGE CONTENT PUSH DOWN — header overlap fix ── */
body {
  padding-top: 92px; /* header height + top */
}

@media screen and (max-width: 990px) {
  body {
    padding-top: 0px; /* mobile par header transparent + no fixed top */
  }
}
</style>


<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>


<!-- ============================================================
     OUTFYST CUSTOM HEADER MARKUP
     ============================================================ -->

<header class="header-OUTFYST">
  <div class="outfyst-header page-width">
    <!-- DESKTOP only: Logo (hidden on mobile via CSS) -->
    <a
      href="{{ routes.root_url }}"
      class="outfyst-header__logo"
      aria-label="{{ shop.name }}"
    >
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ section.settings.logo.alt | default: shop.name }}"
          class="outfyst-header__logo-img"
          width="{{ section.settings.logo.width }}"
          height="{{ section.settings.logo.height }}"
          loading="eager"
        >
      {%- else -%}
        <span class="outfyst-header__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
      {%- endif -%}
    </a>

    <!-- CENTER: Desktop Navigation -->
    {%- if section.settings.menu != blank -%}
      <nav class="outfyst-header__nav" role="navigation" aria-label="Main navigation">
        {%- for link in linklists[section.settings.menu].links -%}
          <a
            href="{{ link.url }}"
            class="outfyst-header__nav-link{% if link.active %} outfyst-header__nav-link--active{% endif %}"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <!-- RIGHT: Icons — Dawn default logic, untouched -->
    <div class="header__icons{% if section.settings.enable_country_selector or section.settings.enable_language_selector %} header__icons--localization header-localization{% endif %}">
      <div class="desktop-localization-wrapper">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form class="small-hide medium-hide" data-prevent-hide>
            {%- form 'localization', id: 'HeaderCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="HeaderCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'HeaderCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {% endif %}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form class="small-hide medium-hide" data-prevent-hide>
            {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="HeaderLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                {%- render 'language-localization', localPosition: 'HeaderLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>

      {% render 'header-search', input_id: 'Search-In-Modal' %}

      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="header__icon--account link focus-inset{% if section.settings.menu != blank %} small-hide{% endif %}"
          rel="nofollow"
        >
          {%- if section.settings.enable_customer_avatar -%}
            <account-icon>
              {%- if customer and customer.has_avatar? -%}
                {{ customer | avatar }}
              {%- else -%}
                <span class="svg-wrapper">{{ 'user-icon.svg' | inline_asset_content }}</span>
              {%- endif -%}
            </account-icon>
          {%- else -%}
            <span class="svg-wrapper">{{ 'user-icon.svg' | inline_asset_content }}</span>
          {%- endif -%}
          <span class="visually-hidden">
            {%- liquid
              if customer
                echo 'customer.account_fallback' | t
              else
                echo 'customer.log_in' | t
              endif
            -%}
          </span>
        </a>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}

      <a href="{{ routes.cart_url }}" class="header__icon--cart link focus-inset" id="cart-icon-bubble">
        {% if cart == empty %}
          <span class="svg-wrapper">{{ 'cart-icon.svg' | inline_asset_content }}</span>
        {% else %}
          <span class="svg-wrapper">{{ 'cart-icon.svg' | inline_asset_content }}</span>
        {% endif %}
        <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
        {%- if cart != empty -%}
          <div class="cart-count-bubble">
            {%- if cart.item_count < 100 -%}
