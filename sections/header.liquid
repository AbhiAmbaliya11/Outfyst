{% comment %} <script>
  (function () {
    var trigger = document.getElementById('outfyst-mobile-search-trigger');
    if (!trigger) return;

    trigger.addEventListener('click', function () {
      var modal = document.querySelector('.header__search .search-modal.modal__content');
      var details = document.querySelector('.header__search details');
      var input = document.querySelector('#Search-In-Modal');

      if (!modal || !details) return;

      details.setAttribute('open', '');
      document.body.style.overflow = 'hidden';

      setTimeout(function () {
        if (input) input.focus();
      }, 100);

      function closeModal() {
        details.removeAttribute('open');
        document.body.style.overflow = '';
      }

      var closeBtn = modal.querySelector('.search-modal__close-button');
      if (closeBtn) closeBtn.addEventListener('click', closeModal, { once: true });

      document.addEventListener('keydown', function onKeydown(e) {
        if (e.key === 'Escape') {
          closeModal();
          document.removeEventListener('keydown', onKeydown);
        }
      });

      modal.addEventListener('click', function onBackdrop(e) {
        if (e.target === modal) {
          closeModal();
          modal.removeEventListener('click', onBackdrop);
        }
      });
    });
  })();
</script> {% endcomment %}
