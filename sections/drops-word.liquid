{% comment %}
  Section: Worlds — Two Drops. One Ethos.
  Block types:
    • drop          → Block 1 & 2: Full left-visual + right-info panel (launched drops)
    • coming_soon   → Block 3 & 4: Two-column coming-soon grid (countdown + image panel)
  All text, colors, URLs, dates fully editable in schema.
  Email notify uses Shopify Customer API → appears in Admin › Customers.
{% endcomment %}

<section
  class="worlds-drops-section"
  id="worlds-drops-{{ section.id }}"
  style="
    --section-bg: {{ section.settings.section_bg_color }};
    --heading-color: {{ section.settings.heading_color }};
    --label-color: {{ section.settings.label_color }};
    --panel-right-bg: {{ section.settings.panel_right_bg_color }};
    --meta-color: {{ section.settings.meta_text_color }};
    --desc-color: {{ section.settings.description_color }};
    --btn-primary-bg: {{ section.settings.btn_primary_bg }};
    --btn-primary-text: {{ section.settings.btn_primary_text_color }};
    --btn-primary-hover-bg: {{ section.settings.btn_primary_hover_bg }};
    --btn-primary-hover-text: {{ section.settings.btn_primary_hover_text_color }};
    --btn-secondary-bg: {{ section.settings.btn_secondary_bg }};
    --btn-secondary-text: {{ section.settings.btn_secondary_text_color }};
    --btn-secondary-border: {{ section.settings.btn_secondary_border_color }};
    --btn-secondary-hover-bg: {{ section.settings.btn_secondary_hover_bg }};
    --btn-secondary-hover-text: {{ section.settings.btn_secondary_hover_text_color }};
    --live-badge-bg: {{ section.settings.live_badge_bg }};
    --live-badge-text: {{ section.settings.live_badge_text_color }};
    --drop-label-color: {{ section.settings.drop_label_color }};
    --drop-headline-color: {{ section.settings.drop_headline_color }};
    --all-drops-color: {{ section.settings.all_drops_color }};
    --all-drops-hover-color: {{ section.settings.all_drops_hover_color }};
  "
>
  <div class="worlds-drops__wrapper">

    {%- comment -%} ── TOP BAR ── {%- endcomment -%}
    <div class="worlds-drops__top-bar">
      <div class="worlds-drops__top-bar-left">
        {%- if section.settings.eyebrow != blank -%}
          <p class="worlds-drops__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.section_heading != blank -%}
          <h2 class="worlds-drops__heading">{{ section.settings.section_heading }}</h2>
        {%- endif -%}
      </div>
      <div class="worlds-drops__top-bar-right">
        {%- if section.settings.all_drops_label != blank and section.settings.all_drops_url != blank -%}
          <a class="worlds-drops__all-drops-link" href="{{ section.settings.all_drops_url }}">
            {{ section.settings.all_drops_label }} &rarr;
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── BLOCK ROWS ── {%- endcomment -%}
    {%- for block in section.blocks -%}

      {%- comment -%} ════════════════════════════════════════
          BLOCK TYPE: drop  (Blocks 1 & 2 — launched drops)
          Layout: big left visual + right info panel
      ════════════════════════════════════════ {%- endcomment -%}
      {%- if block.type == 'drop' -%}

        <div class="worlds-drops__item worlds-drops__item--launched" {{ block.shopify_attributes }}>

          {%- comment -%} LEFT PANEL — Visual {%- endcomment -%}
          <div class="worlds-drops__left-panel">
            <div class="worlds-drops__visual-bg"
              style="
                {%- if block.settings.bg_image != blank -%}
                  background-image: url('{{ block.settings.bg_image | img_url: 'master' }}');
                  background-size: cover;
                  background-position: {{ block.settings.bg_image_position }};
                {%- else -%}
                  background: {{ block.settings.bg_color }};
                {%- endif -%}
              "
            >
              {%- if block.settings.show_texture_overlay -%}
                <div class="worlds-drops__texture-overlay"></div>
              {%- endif -%}

              {%- if block.settings.show_live_badge -%}
                <div class="worlds-drops__live-badge">
                  <span class="worlds-drops__live-dot"></span>
                  {{ block.settings.live_badge_label | default: 'LIVE NOW' }}
                </div>
              {%- endif -%}

              <div class="worlds-drops__visual-footer">
                {%- if block.settings.drop_label != blank -%}
                  <p class="worlds-drops__drop-label">{{ block.settings.drop_label }}</p>
                {%- endif -%}
                {%- if block.settings.drop_headline != blank -%}
                  <h3 class="worlds-drops__drop-headline">{{ block.settings.drop_headline }}</h3>
                {%- endif -%}
              </div>
            </div>
          </div>

          {%- comment -%} RIGHT PANEL — Info + CTA {%- endcomment -%}
          <div class="worlds-drops__right-panel">
            <div class="worlds-drops__right-inner">

              <div class="custom-flex">
              {%- if block.settings.drop_meta != blank -%}
                <p class="worlds-drops__meta">{{ block.settings.drop_meta }}</p>
              {%- endif -%}

              {%- if block.settings.drop_description != blank -%}
                <div class="worlds-drops__description">
                  {{ block.settings.drop_description }}
                </div>
              {%- endif -%}
              </div>

              <div class="worlds-drops__cta-group">
                {%- if block.settings.btn_primary_label != blank and block.settings.btn_primary_url != blank -%}
                  <a
                    class="worlds-drops__btn worlds-drops__btn--primary"
                    href="{{ block.settings.btn_primary_url }}"
                    style="
                      background: {{ block.settings.btn_primary_bg | default: 'var(--btn-primary-bg)' }};
                      color: {{ block.settings.btn_primary_text | default: 'var(--btn-primary-text)' }};
                      --block-btn-primary-hover-bg: {{ block.settings.btn_primary_hover_bg | default: 'var(--btn-primary-hover-bg)' }};
                      --block-btn-primary-hover-text: {{ block.settings.btn_primary_hover_text | default: 'var(--btn-primary-hover-text-color)' }};
                    "
                  >
                    {{ block.settings.btn_primary_label }} &rarr;
                  </a>
                {%- endif -%}

                {%- if block.settings.btn_secondary_label != blank and block.settings.btn_secondary_url != blank -%}
                  <a
                    class="worlds-drops__btn worlds-drops__btn--secondary"
                    href="{{ block.settings.btn_secondary_url }}"
                    style="
                      background: {{ block.settings.btn_secondary_bg | default: 'var(--btn-secondary-bg)' }};
                      color: {{ block.settings.btn_secondary_text | default: 'var(--btn-secondary-text)' }};
                      border-color: {{ block.settings.btn_secondary_border | default: 'var(--btn-secondary-border)' }};
                      --block-btn-secondary-hover-bg: {{ block.settings.btn_secondary_hover_bg | default: 'var(--btn-secondary-hover-bg)' }};
                      --block-btn-secondary-hover-text: {{ block.settings.btn_secondary_hover_text | default: 'var(--btn-secondary-hover-text-color)' }};
                    "
                  >
                    {{ block.settings.btn_secondary_label }}
                  </a>
                {%- endif -%}
              </div>

            </div>
          </div>

        </div>

      {%- endif -%}

      {%- comment -%} ════════════════════════════════════════
          BLOCK TYPE: coming_soon  (Blocks 3 & 4 — upcoming drops)
          Layout: two equal columns side by side
            Left col  → meta, description, countdown, email notify, teaser link
            Right col → image/color background + coming soon badge + drop identity
      ════════════════════════════════════════ {%- endcomment -%}
      {%- if block.type == 'coming_soon' -%}

        {%- comment -%} Generate a unique ID per block for JS countdown + form {%- endcomment -%}
        {%- assign cs_id = 'cs-' | append: block.id -%}

        <div
          class="worlds-drops__coming-soon-row"
          {{ block.shopify_attributes }}
          style="
            --cs-left-bg: {{ block.settings.left_panel_bg }};
            --cs-left-text: {{ block.settings.left_panel_text_color }};
            --cs-meta-color: {{ block.settings.cs_meta_color }};
            --cs-desc-color: {{ block.settings.cs_desc_color }};
            --cs-countdown-color: {{ block.settings.countdown_color }};
            --cs-countdown-label-color: {{ block.settings.countdown_label_color }};
            --cs-notify-btn-bg: {{ block.settings.notify_btn_bg }};
            --cs-notify-btn-text: {{ block.settings.notify_btn_text_color }};
            --cs-notify-input-bg: {{ block.settings.notify_input_bg }};
            --cs-notify-input-text: {{ block.settings.notify_input_text_color }};
            --cs-notify-input-border: {{ block.settings.notify_input_border_color }};
            --cs-teaser-color: {{ block.settings.teaser_link_color }};
            --cs-badge-bg: {{ block.settings.coming_soon_badge_bg }};
            --cs-badge-text: {{ block.settings.coming_soon_badge_text }};
            --cs-drop-label-color: {{ block.settings.cs_drop_label_color }};
            --cs-drop-headline-color: {{ block.settings.cs_drop_headline_color }};
            --cs-launch-date-color: {{ block.settings.launch_date_color }};
          "
        >

          {%- comment -%} LEFT COL — countdown + notify {%- endcomment -%}
          <div class="worlds-drops__cs-left">
            <div class="worlds-drops__cs-left-bg"
              style="
                {%- if block.settings.left_bg_image != blank -%}
                  background-image: url('{{ block.settings.left_bg_image | img_url: 'master' }}');
                  background-size: cover;
                  background-position: center;
                {%- else -%}
                  background: var(--cs-left-bg);
                {%- endif -%}
              "
            >
              {%- if block.settings.show_left_texture -%}
                <div class="worlds-drops__texture-overlay"></div>
              {%- endif -%}

              <div class="worlds-drops__cs-left-inner">

                <div class="block_custom-flex">
                    {%- comment -%} Meta + description {%- endcomment -%}
                    {%- if block.settings.cs_meta != blank -%}
                    <p class="worlds-drops__cs-meta">{{ block.settings.cs_meta }}</p>
                    {%- endif -%}
                    {%- if block.settings.cs_description != blank -%}
                    <p class="worlds-drops__cs-desc">{{ block.settings.cs_description }}</p>
                    {%- endif -%}

                    {%- comment -%} Countdown Timer {%- endcomment -%}
                    {%- if block.settings.launch_datetime != blank -%}
                    <div class="worlds-drops__countdown" id="{{ cs_id }}-countdown" data-launch="{{ block.settings.launch_datetime }}">
                        <div class="worlds-drops__countdown-unit">
                        <span class="worlds-drops__countdown-num" id="{{ cs_id }}-days">00</span>
                        <span class="worlds-drops__countdown-lbl">{{ block.settings.countdown_label_days | default: 'DAYS' }}</span>
                        </div>
                        <div class="worlds-drops__countdown-unit">
                        <span class="worlds-drops__countdown-num" id="{{ cs_id }}-hours">00</span>
                        <span class="worlds-drops__countdown-lbl">{{ block.settings.countdown_label_hours | default: 'HOURS' }}</span>
                        </div>
                        <div class="worlds-drops__countdown-unit">
                        <span class="worlds-drops__countdown-num" id="{{ cs_id }}-mins">00</span>
                        <span class="worlds-drops__countdown-lbl">{{ block.settings.countdown_label_mins | default: 'MIN' }}</span>
                        </div>
                        <div class="worlds-drops__countdown-unit">
                        <span class="worlds-drops__countdown-num" id="{{ cs_id }}-secs">00</span>
                        <span class="worlds-drops__countdown-lbl">{{ block.settings.countdown_label_secs | default: 'SEC' }}</span>
                        </div>
                    </div>
                    {%- endif -%}
                </div>

                {%- comment -%} Email Notify Form — submits to Shopify Customer API {%- endcomment -%}
                <div class="worlds-drops__notify-wrap" id="{{ cs_id }}-notify-wrap">
                  <div class="worlds-drops__notify-form-row" id="{{ cs_id }}-form-row">
                    <input
                      class="worlds-drops__notify-input"
                      id="{{ cs_id }}-email"
                      type="email"
                      placeholder="{{ block.settings.notify_placeholder | default: 'your@email.com' }}"
                      autocomplete="email"
                    >
                    <button
                      class="worlds-drops__notify-btn"
                      type="button"
                      onclick="worldsDropsNotify('{{ cs_id }}', '{{ block.settings.cs_meta | escape }}', '{{ block.settings.cs_description | escape }}')"
                    >
                      {{ block.settings.notify_btn_label | default: 'NOTIFY ME' }}
                    </button>
                  </div>
                  <p class="worlds-drops__notify-success" id="{{ cs_id }}-success" style="display:none;">
                    {{ block.settings.notify_success_msg | default: "You're on the list. Watch this space." }}
                  </p>
                  <p class="worlds-drops__notify-error" id="{{ cs_id }}-error" style="display:none;">
                    {{ block.settings.notify_error_msg | default: 'Something went wrong. Please try again.' }}
                  </p>
                

                {%- comment -%} Teaser link {%- endcomment -%}
                {%- if block.settings.teaser_label != blank and block.settings.teaser_url != blank -%}
                  <a class="worlds-drops__teaser-link" href="{{ block.settings.teaser_url }}">
                    {{ block.settings.teaser_label }} &rarr;
                  </a>
                {%- endif -%}
                </div>

              </div>
            </div>
          </div>

          {%- comment -%} RIGHT COL — visual panel {%- endcomment -%}
          <div class="worlds-drops__cs-right">
            <div class="worlds-drops__cs-right-bg"
              style="
                {%- if block.settings.right_bg_image != blank -%}
                  background-image: url('{{ block.settings.right_bg_image | img_url: 'master' }}');
                  background-size: cover;
                  background-position: {{ block.settings.right_bg_image_position }};
                {%- else -%}
                  background: {{ block.settings.right_bg_color }};
                {%- endif -%}
              "
            >
              {%- if block.settings.show_right_texture -%}
                <div class="worlds-drops__texture-overlay"></div>
              {%- endif -%}

              {%- comment -%} Coming soon badge — top right {%- endcomment -%}
              <div class="worlds-drops__cs-badge-wrap">
                <span class="worlds-drops__cs-badge">
                  {{ block.settings.coming_soon_badge_label | default: 'COMING SOON' }}
                </span>
              </div>

              {%- comment -%} Drop identity — bottom right {%- endcomment -%}
              <div class="worlds-drops__cs-visual-footer">
                {%- if block.settings.cs_drop_label != blank -%}
                  <p class="worlds-drops__cs-drop-label">{{ block.settings.cs_drop_label }}</p>
                {%- endif -%}
                {%- if block.settings.cs_drop_headline != blank -%}
                  <h3 class="worlds-drops__cs-drop-headline">{{ block.settings.cs_drop_headline }}</h3>
                {%- endif -%}
                {%- if block.settings.launch_date_display != blank -%}
                  <p class="worlds-drops__cs-launch-date">{{ block.settings.launch_date_display }}</p>
                {%- endif -%}
              </div>

            </div>
          </div>

        </div>

      {%- endif -%}

    {%- endfor -%}

  </div>
</section>

{%- comment -%} ── STYLES ── {%- endcomment -%}
<style>
  #worlds-drops-{{ section.id }} {
    background-color: var(--section-bg);
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
    font-family: {{ section.settings.font_family }}, sans-serif;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__wrapper {
    max-width: {{ section.settings.section_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.section_padding_x }}px;
  }

  @media(max-width: 768px){
    #worlds-drops-{{ section.id }} .worlds-drops__wrapper {
      padding: 0 1.5rem;
    }
  }

  /* ── TOP BAR ── */
  #worlds-drops-{{ section.id }} .worlds-drops__top-bar {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 24px;
    gap: 16px;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__eyebrow {
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--label-color);
    margin: 0 0 6px;
    font-weight: 600;
    margin-bottom: 14px;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__heading {
    font-size: 56px;
    text-transform: uppercase;
    letter-spacing: -0.025em;
    line-height: 0.95;
    color: var(--heading-color);
    margin: 0;
  }

  /* Apply to your specific section ID */
#worlds-drops-{{ section.id }} .worlds-drops__all-drops-link {
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--all-drops-color);
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.2s ease, letter-spacing 0.3s ease, padding-right 0.3s ease;
  
  /* Ensure the link can handle the movement */
  display: inline-flex;
  align-items: center;
}

/* The Hover State */
#worlds-drops-{{ section.id }} .worlds-drops__all-drops-link:hover {
  /* This pushes the arrow (and the space before it) to the right */
  letter-spacing: 0.25em; 
  padding-right: 5px;
  
  /* Optional: if you want the color to change based on your variable */
  opacity: 0.8; 
}

  #worlds-drops-{{ section.id }} .worlds-drops__all-drops-link:hover {
    color: var(--all-drops-hover-color);
  }

  /* ── DROP ITEM (launched) ── */
  #worlds-drops-{{ section.id }} .worlds-drops__item {
    display: grid;
    grid-template-columns: 2fr 1fr;
    min-height: {{ section.settings.panel_min_height }}px;
    margin-bottom: {{ section.settings.item_gap }}px;
    gap: 24px;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__item:last-child,
  #worlds-drops-{{ section.id }} .worlds-drops__coming-soon-row:last-child {
    margin-bottom: 0;
  }

  /* ── LEFT PANEL (launched) ── */
  #worlds-drops-{{ section.id }} .worlds-drops__left-panel {
    position: relative;
    overflow: hidden;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__visual-bg {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: {{ section.settings.panel_min_height }}px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 20px 28px 28px;
    box-sizing: border-box;
  }

  /* Diagonal stripe texture */
  #worlds-drops-{{ section.id }} .worlds-drops__texture-overlay {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      -55deg,
      transparent,
      transparent 8px,
      rgba(255,255,255,0.03) 8px,
      rgba(255,255,255,0.03) 9px
    );
    pointer-events: none;
  }

  /* ── LIVE BADGE ── */
  #worlds-drops-{{ section.id }} .worlds-drops__live-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--live-badge-bg);
    color: var(--live-badge-text);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 2px;
    position: relative;
    z-index: 1;
    width: fit-content;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--live-badge-text);
    display: inline-block;
    animation: worlds-drops-pulse 1.4s ease-in-out infinite;
  }

  @keyframes worlds-drops-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.7); }
  }

  /* ── VISUAL FOOTER (launched) ── */
  #worlds-drops-{{ section.id }} .worlds-drops__visual-footer {
    position: relative;
    z-index: 1;
    margin-top: auto;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__drop-label {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--drop-label-color);
    margin: 0 0 6px;
    font-weight: 600;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__drop-headline {
    font-size: clamp(36px, 6vw, 80px);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    color: var(--drop-headline-color);
    margin: 0;
  }

  /* ── RIGHT PANEL (launched) ── */
  #worlds-drops-{{ section.id }} .worlds-drops__right-panel {
    background: var(--panel-right-bg);
    display: flex;
    align-items: flex-end;
    padding: 40px 36px;
    box-sizing: border-box;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__right-inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: stretch;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__meta {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--meta-color);
    margin: 0 0 16px;
    font-weight: 600;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__description {
    font-size: 15px;
    line-height: 1.6;
    color: var(--desc-color);
    margin-bottom: 32px;
  }

  /* ── BUTTONS (launched) ── */
  #worlds-drops-{{ section.id }} .worlds-drops__cta-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__btn {
    display: block;
    width: 100%;
    padding: 16px 20px;
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    box-sizing: border-box;
    border: 1px solid transparent;
    cursor: pointer;
    transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease, transform 0.18s ease;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__btn:hover {
    transform: translateY(-1px);
  }

  #worlds-drops-{{ section.id }} .worlds-drops__btn--primary {
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
  }

  #worlds-drops-{{ section.id }} .worlds-drops__btn--primary:hover {
    background: var(--btn-primary-hover-bg) !important;
    color: var(--btn-primary-hover-text) !important;
  }

  #worlds-drops-{{ section.id }} .worlds-drops__btn--secondary {
    background: var(--btn-secondary-bg);
    color: var(--btn-secondary-text);
    border-color: var(--btn-secondary-border);
  }

  #worlds-drops-{{ section.id }} .worlds-drops__btn--secondary:hover {
    background: var(--btn-secondary-hover-bg) !important;
    color: var(--btn-secondary-hover-text) !important;
  }

  /* ═══════════════════════════════════════
     COMING SOON ROW (Blocks 3 & 4)
  ═══════════════════════════════════════ */
  #worlds-drops-{{ section.id }} .worlds-drops__coming-soon-row {
    display: grid;
    grid-template-columns: 1fr 2fr;
    min-height: {{ section.settings.panel_min_height }}px;
    margin-bottom: {{ section.settings.item_gap }}px;
    align-items: stretch;
    gap: 24px;
  }

  /* LEFT COL */
  #worlds-drops-{{ section.id }} .worlds-drops__cs-left {
    position: relative;
    overflow: hidden;
  }

