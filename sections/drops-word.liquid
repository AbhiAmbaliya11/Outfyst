{%- comment -%} ── JAVASCRIPT: Countdown + Email Notify ── {%- endcomment -%}
<script>
(function() {
  /* ── Countdown Timers ── */
  document.querySelectorAll('#worlds-drops-{{ section.id }} .worlds-drops__countdown').forEach(function(el) {
    var launch = new Date(el.dataset.launch).getTime();
    var id     = el.id.replace('-countdown', '');

    function pad(n) { return String(n).padStart(2, '0'); }

    function tick() {
      var now  = Date.now();
      var diff = launch - now;

      if (diff <= 0) {
        document.getElementById(id + '-days').textContent  = '00';
        document.getElementById(id + '-hours').textContent = '00';
        document.getElementById(id + '-mins').textContent  = '00';
        document.getElementById(id + '-secs').textContent  = '00';
        return;
      }

      var days  = Math.floor(diff / 86400000);
      var hours = Math.floor((diff % 86400000) / 3600000);
      var mins  = Math.floor((diff % 3600000)  / 60000);
      var secs  = Math.floor((diff % 60000)    / 1000);

      document.getElementById(id + '-days').textContent  = pad(days);
      document.getElementById(id + '-hours').textContent = pad(hours);
      document.getElementById(id + '-mins').textContent  = pad(mins);
      document.getElementById(id + '-secs').textContent  = pad(secs);
    }

    tick();
    setInterval(tick, 1000);
  });

  /* ── Email Notify → Shopify Customer API ── */
  window.worldsDropsNotify = function(csId, dropMeta, dropDesc) {
    var emailInput = document.getElementById(csId + '-email');
    var btn        = document.querySelector('#' + csId + '-form-row .worlds-drops__notify-btn');
    var successEl  = document.getElementById(csId + '-success');
    var errorEl    = document.getElementById(csId + '-error');
    var email      = (emailInput ? emailInput.value : '').trim();

    successEl.style.display = 'none';
    errorEl.style.display   = 'none';

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorEl.textContent   = 'Please enter a valid email address.';
      errorEl.style.display = 'block';
      return;
    }

    if (btn) {
      btn.disabled     = true;
      btn.textContent  = '...';
    }

    /* Build note tag so admin can identify which drop this is for */
    var note = 'Notify Me Request — ' + (dropMeta || 'Coming Soon Drop');
    if (dropDesc) note += ' | ' + dropDesc;

    fetch('/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        form_type: 'customer',
        utf8:      '✓',
        'customer[email]':        email,
        'customer[tags]':         'drop-notify',
        'customer[note]':         note,
        'customer[accepts_marketing]': 'true'
      }).toString()
    })
    .then(function(res) {
      if (res.ok || res.redirected) {
        successEl.style.display = 'block';
        if (emailInput) emailInput.value = '';
        var formRow = document.getElementById(csId + '-form-row');
        if (formRow) formRow.style.display = 'none';
      } else {
        throw new Error('server error');
      }
    })
    .catch(function() {
      /* Fallback: Shopify /contact form (always works) */
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = '/contact';
      form.style.display = 'none';

      var fields = {
        form_type: 'contact',
        utf8:      '✓',
        'contact[email]':   email,
        'contact[subject]': 'Drop Notify — ' + (dropMeta || 'Coming Soon'),
        'contact[body]':    'Email: ' + email + '\n\nDrop: ' + (dropMeta || '') + '\n' + (dropDesc || '') + '\n\nThis customer wants to be notified when the drop launches.'
      };

      Object.keys(fields).forEach(function(k) {
        var inp = document.createElement('input');
        inp.type  = 'hidden';
        inp.name  = k;
        inp.value = fields[k];
        form.appendChild(inp);
      });

      document.body.appendChild(form);
      form.submit();
    });

    if (btn) {
      setTimeout(function() {
        if (btn.disabled) {
          btn.disabled    = false;
          btn.textContent = btn.getAttribute('data-label') || 'NOTIFY ME';
        }
      }, 8000);
    }
  };
})();
</script>

