<section class="earned-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="earned-wrapper">
    
    <!-- NEW TOP HEADER ROW -->
    <div class="earned-header">
      <div class="header-left">
        <p class="earned-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="earned-heading">{{ section.settings.heading }}</h2>
      </div>
      <div class="header-right">
        <a href="{{ section.settings.top_link }}" class="earned-link">
  {{ section.settings.top_link_text }} <span class="arrow">→</span>
</a>
      </div>
    </div>

    <div class="earned-container">
      <!-- LEFT SIDE (Image/Pattern) -->
      <div class="earned-left 
        {% if section.settings.left_mode == 'pattern' %}pattern-bg{% endif %}"
        style="
          {% if section.settings.left_mode == 'color' %}
            background-color: {{ section.settings.left_bg_color }};
          {% endif %}
          {% if section.settings.left_mode == 'image' and section.settings.left_image != blank %}
            background-image: url({{ section.settings.left_image | image_url: width: 1400 }});
          {% endif %}
        "
      >
        <div class="earned-caption">
          {{ section.settings.caption }}
        </div>
      </div>

      <!-- RIGHT SIDE (Content) -->
      <div class="earned-right">
        <div class="earned-content">
          <h3 class="earned-subheading">
            {{ section.settings.subheading }}
          </h3>

          <p class="earned-text">{{ section.settings.text }}</p>
          <p class="earned-text small">{{ section.settings.small_text }}</p>

          <!-- LIST -->
          <div class="earned-list">
            {% for block in section.blocks %}
              <div class="earned-item">
                <div class="num">{{ block.settings.number }}</div>
                <div class="info">
                  <div class="earned-item-title">{{ block.settings.title }}</div>
                  <div class="earned-item-desc">{{ block.settings.desc }}</div>
                </div>
                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}" class="arrow">→</a>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
.earned-section {
  padding: 80px 60px;
  font-family: inherit; /* Inherits your theme's font */
}

.earned-wrapper {
  max-width: 1400px;
  margin: 0 auto;
}

/* NEW HEADER LAYOUT */
.earned-header {
    max-width: 1600px;
    margin: 0px auto;
    padding: 30px 0px 32px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
}

.earned-eyebrow {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.22em;
  color: rgb(90, 90, 90);
  text-transform: uppercase;
  margin-bottom: 14px;
  display: block;
  opacity: 0.8;
}

.earned-heading {
  font-size: 56px;
  margin: 0;
  line-height: 0.95;
  text-transform: uppercase;
  color: rgb(11, 11, 11);
  letter-spacing: -0.025em;
}

.earned-link {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: rgb(11, 11, 11);
  text-transform: uppercase;
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
  padding-bottom: 10px;
  display: inline-flex;
  align-items: center;
}

.earned-link .arrow {
  display: inline-block;
  margin-left: 8px; /* Space between text and arrow */
  transition: transform 0.3s ease; /* Smooth movement */
}

/* The Animation Trigger */
.earned-link:hover .arrow {
  transform: translateX(5px); /* Moves arrow 5px to the right */
}

/* GRID CONTAINER */
.earned-container {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr; /* Slightly larger image side */
  gap: 46px;
  align-items: center;
}

/* LEFT SIDE */
.earned-left {
  position: relative;
  min-height: 650px;
  background-size: cover;
  background-position: center;
}

.pattern-bg {
  background: linear-gradient(135deg, #2c2c2c, #1a1a1a);
  aspect-ratio: 4 / 5;
  position: relative;
  overflow: hidden;
}

.pattern-bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(
    135deg,
    rgba(255,255,255,0.05) 0px,
    rgba(255,255,255,0.05) 1px,
    transparent 1px,
    transparent 12px
  );
}

.earned-caption {
  position: absolute;
  bottom: 20px;
  left: 20px;
  font-size: 10px;
  letter-spacing: 1px;
  color: #fff;
  opacity: 0.6;
}

/* RIGHT SIDE CONTENT */
.earned-subheading {
  font-size: 54px;
  line-height: 0.95;
  letter-spacing: -0.025em;
  text-transform: uppercase;
  margin-bottom: 28px;
}

.earned-text {
  font-size: 15px;
  line-height: 1.6;
  margin: 0px 0px 18px;
  max-width: 90%;
  color: rgb(11, 11, 11);
}

.earned-text.small {
  font-size: 13px;
  opacity: 0.7;
}

/* LIST STYLES */
.earned-list {
  margin-top: 40px;
  border-top: 1px solid #000;
}

.earned-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid rgba(0,0,0,0.1);
  transition: all 0.3s ease;
}

.earned-item .num {
  color: rgb(139, 15, 26);
  letter-spacing: -0.02em;
  width: 50px;
  font-size: 24px;
  font-family: "Archivo Black", sans-serif;
}

.earned-item .earned-item-title {
  font-size: 14px;
  font-weight: 600;
}

.earned-item .earned-item-desc {
  font-size: 13px;
  color: rgb(90, 90, 90);
  margin-top: 3px;
}

.earned-item .arrow {
  margin-left: auto;
  text-decoration: none;
  color: #000;
  font-size: 18px;
  /* Add these two lines */
  display: inline-block; 
  transition: transform 0.3s ease, color 0.3s ease;
}

.earned-item .arrow:hover {
  transform: translateX(5px); /* Moves it 5px to the right */
  color: #555; /* Optional: slightly fades the color */
}

/* MOBILE RESPONSIVENESS */
@media (max-width: 1024px) {
  .earned-container {
    gap: 40px;
  }
}

@media (max-width: 768px) {
  .earned-section {
    padding: 40px 20px;
  }
  
  .earned-header {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .header-right {
    margin-top: 20px;
  }

  .earned-container {
    grid-template-columns: 1fr;
  }

  .earned-left {
    min-height: 400px;
    order: 2; /* Moves image below heading on mobile */
  }
  
  .earned-right {
    order: 3;
  }

  .earned-heading {
    font-size: 36px;
  }
}
</style>

{% schema %}
{
  "name": "Earned Story Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#efede9"
    },
    {
      "type": "select",
      "id": "left_mode",
      "label": "Left Side Background Type",
      "options": [
        { "value": "pattern", "label": "Pattern (like design)" },
        { "value": "image", "label": "Image" },
        { "value": "color", "label": "Solid Color" }
      ],
      "default": "pattern"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Image"
    },
    {
      "type": "color",
      "id": "left_bg_color",
      "label": "Left Background Color",
      "default": "#333333"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Bottom Caption",
      "default": "FOUNDERS · BOMBAY 2025"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Top Small Text",
      "default": "OUR STORY"
    },
    {
      "type": "text",
      "id": "top_link_text",
      "label": "Top Link Text",
      "default": "READ FULL STORY"
    },
    {
      "type": "url",
      "id": "top_link",
      "label": "Top Link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "BUILT TO BE EARNED."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub Heading",
      "default": "FROM A WORKSHOP IN BOMBAY."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Main Text"
    },
    {
      "type": "textarea",
      "id": "small_text",
      "label": "Small Text"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "List Item",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "desc", "label": "Description" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Earned Story Section",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}