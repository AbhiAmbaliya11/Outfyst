          "max": 10,
          "step": 1,
          "default": -1
        },
        {
          "type": "select",
          "id": "stage_title_text_transform",
          "label": "Stage Title Text Transform",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "uppercase", "label": "UPPERCASE" },
            { "value": "lowercase", "label": "lowercase" },
            { "value": "capitalize", "label": "Capitalize" }
          ],
          "default": "uppercase"
        },
        {
          "type": "header",
          "content": "📄 Stage Description"
        },
        {
          "type": "textarea",
          "id": "stage_description",
          "label": "Stage Description",
          "default": "Where the story begins. No edge, no inheritance."
        },
        {
          "type": "color",
          "id": "stage_description_color",
          "label": "Stage Description Color",
          "default": "#999999"
        },
        {
          "type": "range",
          "id": "stage_description_font_size",
          "label": "Stage Description Font Size (px)",
          "min": 10,
          "max": 24,
          "step": 1,
          "default": 14
        },
        {
          "type": "select",
          "id": "stage_description_font_weight",
          "label": "Stage Description Font Weight",
          "options": [
            { "value": "300", "label": "Light" },
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" }
          ],
          "default": "400"
        },
        {
          "type": "range",
          "id": "stage_description_line_height",
          "label": "Stage Description Line Height (× 10)",
          "min": 10,
          "max": 20,
          "step": 1,
          "default": 16
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Narrative Arc",
      "blocks": [
        { "type": "stage" },
        { "type": "stage" },
        { "type": "stage" },
        { "type": "stage" }
      ]
    }
  ]
}
{% endschema %}