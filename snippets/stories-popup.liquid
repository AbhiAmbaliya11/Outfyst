{% comment %} {% comment %}
  Snippet: stories-popup.liquid
  Path: snippets/stories-popup.liquid
  Include with: {% render 'stories-popup' %}
  Trigger: any element with data-stories-open="stories-popup"

  To add slides: edit the SLIDES array in the <script> block below.
{% endcomment %}

<style>
  #stories-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.82);
    align-items: center;
    justify-content: center;
  }
  #stories-overlay.is-open {
    display: flex;
  }

  .stories-modal {
    position: relative;
    width: min(420px, 96vw);
    height: min(748px, 92vh);
    background: #111;
    overflow: hidden;
    border-radius: 12px;
  }

  .stories-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .stories-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  .stories-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .stories-progress {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    display: flex;
    gap: 4px;
    padding: 10px 12px 6px;
  }
  .stories-progress__bar {
    flex: 1;
    height: 2px;
    background: rgba(255,255,255,0.35);
    border-radius: 2px;
    overflow: hidden;
  }
  .stories-progress__fill {
    height: 100%;
    width: 0%;
    background: #fff;
    border-radius: 2px;
  }
  .stories-progress__bar.done .stories-progress__fill {
    width: 100%;
  }
  .stories-progress__bar.active .stories-progress__fill {
    animation: stories-fill var(--stories-duration, 5s) linear forwards;
  }
  @keyframes stories-fill {
    from { width: 0% }
    to   { width: 100% }
  }

  .stories-header {
    position: absolute;
    top: 22px;
    left: 0;
    right: 0;
    z-index: 11;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 14px;
  }
  .stories-brand {
    font-family: 'Archivo Black', 'Arial Black', sans-serif;
    font-size: 15px;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #E8650A;
  }
  .stories-controls {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .stories-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .stories-tap {
    position: absolute;
    top: 0;
    bottom: 80px;
    width: 40%;
    z-index: 5;
    cursor: pointer;
  }
  .stories-tap--prev { left: 0; }
  .stories-tap--next { right: 0; }

  .stories-cta {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 12;
    white-space: nowrap;
  }
  .stories-cta a {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 0 32px;
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.55);
    border-radius: 100px;
    color: #fff;
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: background 0.2s;
  }
  .stories-cta a:hover {
    background: rgba(255,255,255,0.28);
  }

  .stories-side-pause {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 13;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .stories-side-pause span {
    display: block;
    width: 2px;
    height: 18px;
    background: rgba(255,255,255,0.5);
    border-radius: 2px;
  }

  @media (max-width: 990px) {
    .stories-modal {
      width: 100vw;
      height: 100dvh;
      border-radius: 0;
    }
    #stories-overlay {
      align-items: flex-start;
    }
  }
</style>

<div id="stories-overlay" role="dialog" aria-modal="true" aria-label="Stories">
  <div class="stories-modal" id="stories-modal">

    <div class="stories-progress" id="stories-progress"></div>

    <div class="stories-header">
      <span class="stories-brand" id="stories-brand-label"></span>
      <div class="stories-controls">
        <button class="stories-btn" id="stories-pause-btn" aria-label="Pause">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="3" y="2" width="4" height="14" rx="1.5" fill="white"/>
            <rect x="11" y="2" width="4" height="14" rx="1.5" fill="white"/>
          </svg>
        </button>
        <button class="stories-btn" id="stories-close-btn" aria-label="Close">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <line x1="2" y1="2" x2="16" y2="16" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <line x1="16" y1="2" x2="2" y2="16" stroke="white" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div id="stories-slides-wrap"></div>

    <div class="stories-tap stories-tap--prev" id="stories-prev"></div>
    <div class="stories-tap stories-tap--next" id="stories-next"></div>
    <div class="stories-side-pause"><span></span><span></span></div>

  </div>
</div>

<script>
(function () {

  /* ── SLIDES CONFIG ─────────────────────────────────────────────────────
     Drekk slide mate ek object add karo.
     image_url : Shopify CDN image URL  (niche Liquid filters vaparo)
     brand     : top-left orange label
     cta_label : Shop Now button text
     cta_url   : Shop Now button link
     duration  : seconds (default 5)
  ──────────────────────────────────────────────────────────────────────── */
  var SLIDES = [
    {
      image_url: '{{ collections["polo-season"].featured_image | image_url: width: 900 }}',
      brand: 'Polo Season',
      cta_label: 'Shop Now',
      cta_url: '/collections/polo-season',
      duration: 5
    },
    {
      image_url: '{{ collections["black-grid"].featured_image | image_url: width: 900 }}',
      brand: 'Black Grid',
      cta_label: 'Shop Now',
      cta_url: '/collections/black-grid',
      duration: 5
    }
    /* Add more:
    ,{
      image_url: '{{ collections["your-handle"].featured_image | image_url: width: 900 }}',
      brand: 'Your Label',
      cta_label: 'Shop Now',
      cta_url: '/collections/your-handle',
      duration: 6
    }
    */
  ];

  /* ── DOM ───────────────────────────────────────────────── */
  var overlay    = document.getElementById('stories-overlay');
  var progress   = document.getElementById('stories-progress');
  var slidesWrap = document.getElementById('stories-slides-wrap');
  var brandLabel = document.getElementById('stories-brand-label');
  var closeBtn   = document.getElementById('stories-close-btn');
  var pauseBtn   = document.getElementById('stories-pause-btn');
  var prevZone   = document.getElementById('stories-prev');
  var nextZone   = document.getElementById('stories-next');

  var current   = 0;
  var paused    = false;
  var timer     = null;
  var animStart = null;
  var elapsed   = 0;
  var bars      = [];
  var slideEls  = [];

  /* ── BUILD DOM ─────────────────────────────────────────── */
  SLIDES.forEach(function (s, i) {
    var bar  = document.createElement('div');
    bar.className = 'stories-progress__bar';
    bar.dataset.index = i;
    var fill = document.createElement('div');
    fill.className = 'stories-progress__fill';
    bar.appendChild(fill);
    progress.appendChild(bar);
    bars.push(bar);

    var slide = document.createElement('div');
    slide.className = 'stories-slide' + (i === 0 ? ' is-active' : '');
    slide.dataset.index = i;
    slide.dataset.duration = s.duration || 5;

    if (s.image_url && s.image_url.indexOf('null') === -1 && s.image_url !== '') {
      var img = document.createElement('img');
      img.src = s.image_url;
      img.alt = s.brand || '';
      img.loading = 'lazy';
      slide.appendChild(img);
    }

    var cta = document.createElement('div');
    cta.className = 'stories-cta';
    cta.innerHTML = '<a href="' + (s.cta_url || '#') + '">' + (s.cta_label || 'Shop Now') + '</a>';
    slide.appendChild(cta);

    slidesWrap.appendChild(slide);
    slideEls.push(slide);
  });

  /* ── LOGIC ─────────────────────────────────────────────── */
  function getDuration(idx) {
    return (parseInt(slideEls[idx].dataset.duration, 10) || 5) * 1000;
  }

  function setSlide(idx, fromEl) {
    clearTimeout(timer);
    slideEls.forEach(function (s, i) { s.classList.toggle('is-active', i === idx); });
    bars.forEach(function (b, i) {
      b.classList.remove('active', 'done');
      var f = b.querySelector('.stories-progress__fill');
      f.style.animation = 'none';
      f.style.width = i < idx ? '100%' : '0%';
    });
    current = idx;
    brandLabel.textContent = SLIDES[idx].brand || '';
    if (!paused) startBar(fromEl || 0);
  }

  function startBar(from) {
    var bar  = bars[current];
    var fill = bar.querySelector('.stories-progress__fill');
    var dur  = getDuration(current);
    var rem  = dur - (from || 0);
    bar.classList.add('active');
    fill.style.animation = 'none';
    fill.offsetWidth;
    fill.style.width = ((from / dur) * 100) + '%';
    fill.style.animation = 'stories-fill ' + (rem / 1000) + 's linear forwards';
    bar.style.setProperty('--stories-duration', (rem / 1000) + 's');
    animStart = Date.now() - (from || 0);
    timer = setTimeout(function () {
      current < slideEls.length - 1 ? setSlide(current + 1) : closeStories();
    }, rem);
  }

  function pauseStories() {
    if (paused) return;
    paused = true;
    elapsed = Date.now() - animStart;
    clearTimeout(timer);
    bars[current].querySelector('.stories-progress__fill').style.animationPlayState = 'paused';
    pauseBtn.setAttribute('aria-label', 'Play');
    pauseBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><polygon points="4,2 16,9 4,16" fill="white"/></svg>';
  }

  function resumeStories() {
    if (!paused) return;
    paused = false;
    bars[current].querySelector('.stories-progress__fill').style.animationPlayState = 'running';
    pauseBtn.setAttribute('aria-label', 'Pause');
    pauseBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="3" y="2" width="4" height="14" rx="1.5" fill="white"/><rect x="11" y="2" width="4" height="14" rx="1.5" fill="white"/></svg>';
    startBar(elapsed);
  }

  function openStories() {
    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    paused = false;
    elapsed = 0;
    setSlide(0);
  }

  function closeStories() {
    overlay.classList.remove('is-open');
    document.body.style.overflow = '';
    clearTimeout(timer);
    paused = false;
  }

  closeBtn.addEventListener('click', closeStories);
  overlay.addEventListener('click', function (e) { if (e.target === overlay) closeStories(); });
  pauseBtn.addEventListener('click', function () { paused ? resumeStories() : pauseStories(); });
  prevZone.addEventListener('click', function () { setSlide(current > 0 ? current - 1 : 0); });
  nextZone.addEventListener('click', function () { current < slideEls.length - 1 ? setSlide(current + 1) : closeStories(); });

  document.addEventListener('keydown', function (e) {
    if (!overlay.classList.contains('is-open')) return;
    if (e.key === 'Escape') closeStories();
    if (e.key === 'ArrowRight') nextZone.click();
    if (e.key === 'ArrowLeft') prevZone.click();
  });

  window.storiesOpen = openStories;

  document.addEventListener('click', function (e) {
    var t = e.target.closest('[data-stories-open]');
    if (t) { e.preventDefault(); openStories(); }
  });

})();
</script> {% endcomment %}
