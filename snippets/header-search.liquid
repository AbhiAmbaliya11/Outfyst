{% comment %}
  Renders a header search modal. Should be used with 'header.liquid'

  Accepts:
  - input_id: {String} Id for the search input element (required)

  Usage:
  {% render 'header-search', input_id: 'My-Id'%}
{% endcomment %}

<details-modal class="header__search">
  <details>
    <summary
      class="header__icon--search header__icon--summary link focus-inset modal__toggle"
      aria-haspopup="dialog"
      aria-label="{{ 'general.search.search' | t }}"
    >
      <span>
        <span class="svg-wrapper">
          {{- 'search-icon.svg' | inline_asset_content -}}
        </span>
        {% comment %} <span class="svg-wrapper header__icon-close">
          {{- 'search-icon.svg' | inline_asset_content -}}
        </span> {% endcomment %}
      </span>
    </summary>
    <div
      class="search-modal modal__content gradient"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'general.search.search' | t }}"
    >
      <div class="modal-overlay"></div>
      <div
        class="search-modal__content{% if settings.inputs_shadow_vertical_offset != 0 and settings.inputs_shadow_vertical_offset < 0 %} search-modal__content-top{% else %} search-modal__content-bottom{% endif %}"
        tabindex="-1"
      >
        <!-- ── STORE BRANDING HEADER ── -->
        <div class="search-modal__branding">
          <div class="search-modal__branding-logo">
            {%- if settings.logo != blank -%}
              <img
                src="https://cdn.shopify.com/s/files/1/0758/6139/3571/files/Black_Logo.png?v=1778314055"
                alt="{{ shop.name }}"
                width="120"
                height="auto"
                loading="eager"
              >
            {%- else -%}
              <span class="search-modal__branding-shopname">{{ shop.name }}</span>
            {%- endif -%}
          </div>
          <div class="search-modal__branding-text">
            <p class="search-modal__branding-welcome">Welcome to {{ shop.name }}</p>
            <p class="search-modal__branding-tagline">
              T-Shirts &nbsp;·&nbsp; Hoodies &nbsp;·&nbsp; Shirt's &nbsp;·&nbsp; full sleeve T-shirt &nbsp;·&nbsp; Polo T-shirt
            </p>
          </div>
        </div>
        <!-- ── END BRANDING ── -->

        {%- if settings.predictive_search_enabled -%}
          <predictive-search class="search-modal__form" data-loading-text="{{ 'accessibility.loading' | t }}">
        {%- else -%}
          <search-form class="search-modal__form">
        {%- endif -%}
        <form action="{{ routes.search_url }}" method="get" role="search" class="search search-modal__form">
          <div class="field search-field-custom">
            <input
              class="search__input field__input"
              id="{{ input_id }}"
              type="search"
              name="q"
              value="{{ search.terms | escape }}"
              placeholder="{{ 'general.search.search' | t }} here...."
              {%- if settings.predictive_search_enabled -%}
                role="combobox"
                aria-expanded="false"
                aria-owns="predictive-search-results"
                aria-controls="predictive-search-results"
                aria-haspopup="listbox"
                aria-autocomplete="list"
                autocorrect="off"
                autocomplete="off"
                autocapitalize="off"
                spellcheck="false"
              {%- endif -%}
            >
            <label class="field__label" for="{{ input_id }}">{{ 'general.search.search' | t }}</label>
            <input type="hidden" name="options[prefix]" value="last">
            <button
              type="reset"
              class="reset__button field__button{% if search.terms == blank %} hidden{% endif %}"
              aria-label="{{ 'general.search.reset' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-reset.svg' | inline_asset_content -}}
              </span>
            </button>
            <button class="search__button field__button" aria-label="{{ 'general.search.search' | t }}">
              <span class="svg-wrapper">
                {{- 'icon-search.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          {%- if settings.predictive_search_enabled -%}
            <div class="predictive-search predictive-search--header" tabindex="-1" data-predictive-search>
              {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
            </div>
            <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
          {%- endif -%}
        </form>
        {%- if settings.predictive_search_enabled -%}
          </predictive-search>
        {%- else -%}
          </search-form>
        {%- endif -%}
        <button
          type="button"
          class="search-modal__close-button modal__close-button link link--text focus-inset"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>
    </div>
  </details>
</details-modal>

<style>
  .header__search > details {
    position: static !important;
    overflow: visible !important;
  }

  /* ── BLURRED FULL-SCREEN BACKDROP ── */
  .header__search .search-modal.modal__content {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    z-index: 10000 !important;
    /* frosted glass dark overlay */
    background: rgba(10, 10, 10, 0.55) !important;
    backdrop-filter: blur(8px) !important;
    -webkit-backdrop-filter: blur(8px) !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: flex-start !important;
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    overflow-y: auto !important;
    animation: backdropFadeIn 0.3s ease forwards !important;
  }

  @keyframes backdropFadeIn {
    from { opacity: 0; backdrop-filter: blur(0px); }
    to   { opacity: 1; backdrop-filter: blur(8px); }
  }

  /* Hide dawn's own overlay div */
  .header__search .modal-overlay {
    display: none !important;
  }

  /* ── FLOATING CARD PANEL ── */
  .header__search .search-modal__content {
    position: relative !important;
    width: 92% !important;
    max-width: 860px !important;
    background: #f7f7f7 !important;
    border-radius: 20px !important;
    margin-top: 6rem !important;
    margin-bottom: 3rem !important;
    padding: 2.4rem 2.8rem 2.8rem !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 0 !important;
    box-shadow:
      0 2px 6px rgba(0,0,0,0.06),
      0 16px 48px rgba(0,0,0,0.22),
      0 0 0 1px rgba(255,255,255,0.08) !important;
    animation: cardSlideDown 0.35s cubic-bezier(0.22, 1, 0.36, 1) forwards !important;
    overflow-y: auto !important;
    max-height: calc(100vh - 10rem) !important;
    box-sizing: border-box !important;
  }

  @keyframes cardSlideDown {
    from { transform: translateY(-40px) scale(0.97); opacity: 0; }
    to   { transform: translateY(0)     scale(1);    opacity: 1; }
  }

  /* ── BRANDING ROW ── */
  .header__search .search-modal__branding {
    display: flex !important;
    align-items: center !important;
    gap: 1.4rem !important;
    padding-bottom: 1.6rem !important;
    margin-bottom: 1.6rem !important;
    border-bottom: 1px solid #e2e2e2 !important;
  }

  .header__search .search-modal__branding-logo {
    flex-shrink: 0 !important;
    display: flex !important;
    align-items: center !important;
  }

  .header__search .search-modal__branding-logo img {
    max-height: 38px !important;
    width: auto !important;
    object-fit: contain !important;
    display: block !important;
  }

  .header__search .search-modal__branding-shopname {
    font-size: 22px !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    color: #111 !important;
    white-space: nowrap !important;
  }

  .header__search .search-modal__branding-text {
    border-left: 1.5px solid #ddd !important;
    padding-left: 1.4rem !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 3px !important;
  }

  .header__search .search-modal__branding-welcome {
    font-size: 13px !important;
    font-weight: 700 !important;
    color: #111 !important;
    margin: 0 !important;
    letter-spacing: -0.01em !important;
  }

  .header__search .search-modal__branding-tagline {
    font-size: 11px !important;
    color: #999 !important;
    margin: 0 !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    font-weight: 500 !important;
  }

  /* ── CLOSE BUTTON ── top-right of card */
  .header__search .search-modal__close-button.modal__close-button {
    position: absolute !important;
    top: 1.8rem !important;
    right: 1.8rem !important;
    background: rgba(0,0,0,0.07) !important;
    border: none !important;
    border-radius: 50% !important;
    cursor: pointer !important;
    color: #444 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 7px !important;
    width: 34px !important;
    height: 34px !important;
    box-shadow: none !important;
    transition: background 0.15s, color 0.15s !important;
    z-index: 5 !important;
    transform: none !important;
  }

  .header__search .search-modal__close-button.modal__close-button:hover {
    background: rgba(0,0,0,0.14) !important;
    color: #000 !important;
  }

  .header__search .search-modal__close-button svg {
    width: 16px !important;
    height: 16px !important;
  }

  /* ── SEARCH FORM ── */
  .header__search .search-modal__form {
    width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
    position: relative !important;
  }

  /* ── PILL INPUT ── */
  .header__search .search-field-custom {
    display: flex !important;
    align-items: center !important;
    background: #ebebeb !important;
    border-radius: 100px !important;
    padding: 0 14px 0 22px !important;
    height: 52px !important;
    border: 1.5px solid transparent !important;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s !important;
    margin: 0 !important;
    position: relative !important;
  }

  .header__search .search-field-custom:focus-within {
    border-color: #c8c8c8 !important;
    background: #fff !important;
    box-shadow: 0 0 0 4px rgba(0,0,0,0.05) !important;
  }

  .header__search .search-field-custom .field__label {
    display: none !important;
  }

  .header__search .search-field-custom .search__input.field__input {
    flex: 1 !important;
    background: transparent !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    font-size: 15px !important;
    color: #111 !important;
    padding: 0 !important;
    height: 100% !important;
    letter-spacing: -0.01em !important;
    -webkit-appearance: none !important;
  }

  .header__search .search-field-custom .search__input.field__input::placeholder {
    color: #aaa !important;
  }

  .header__search .search-field-custom .search__input[type="search"]::-webkit-search-cancel-button,
  .header__search .search-field-custom .search__input[type="search"]::-webkit-search-decoration {
    -webkit-appearance: none !important;
    display: none !important;
  }

  .header__search .search-field-custom .reset__button,
  .header__search .search-field-custom .search__button {
    background: none !important;
    border: none !important;
    cursor: pointer !important;
    padding: 6px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: #888 !important;
    flex-shrink: 0 !important;
    position: static !important;
    width: auto !important;
    height: auto !important;
    box-shadow: none !important;
    transition: color 0.15s !important;
  }

  .header__search .search-field-custom .reset__button:hover,
  .header__search .search-field-custom .search__button:hover {
    color: #111 !important;
  }

  .header__search .search-field-custom .reset__button svg,
  .header__search .search-field-custom .search__button svg {
    width: 18px !important;
    height: 18px !important;
  }

  /* ── PREDICTIVE SEARCH ── */
  .header__search .predictive-search.predictive-search--header {
    position: static !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
    width: 100% !important;
    border-radius: 0 !important;
    overflow: visible !important;
  }

  .header__search #predictive-search-results {
    width: 100% !important;
  }

  /* ── TWO-COLUMN GRID ── */
  .header__search #predictive-search-results-groups-wrapper {
    display: grid !important;
    grid-template-columns: 24rem 1fr !important;
    gap: 0 3.2rem !important;
    border-top: 1px solid #e2e2e2 !important;
    padding-top: 1.8rem !important;
    margin-top: 1.8rem !important;
    align-items: start !important;
  }

  .header__search #predictive-search-results-groups-wrapper.predictive-search__results-groups-wrapper--no-products,
  .header__search #predictive-search-results-groups-wrapper.predictive-search__results-groups-wrapper--no-suggestions {
    grid-template-columns: 1fr !important;
  }

  .header__search .predictive-search__result-group:first-child {
    display: flex !important;
    flex-direction: column !important;
    gap: 1.4rem !important;
  }

  .header__search .predictive-search__result-group:last-child:not(:first-child) {
    border-left: 1px solid #e2e2e2 !important;
    padding-left: 3rem !important;
  }

  /* ── SECTION HEADINGS ── */
  .header__search .predictive-search__heading {
    font-size: 10px !important;
    font-weight: 700 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
    color: #aaa !important;
    margin: 0 0 0.6rem !important;
    display: block !important;
    padding-bottom: 0.8rem !important;
    border-bottom: 1px solid #e2e2e2 !important;
  }

  /* ── LIST RESET ── */
  .header__search .predictive-search__results-list {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
    display: flex !important;
    flex-direction: column !important;
  }

  .header__search .predictive-search__list-item {
    margin: 0 !important;
    padding: 0 !important;
  }

  /* ── SUGGESTION ITEMS ── */
  .header__search .predictive-search__result-group:first-child .predictive-search__list-item {
    border-bottom: 1px solid #ececec !important;
  }

  .header__search .predictive-search__result-group:first-child .predictive-search__list-item:last-child {
    border-bottom: none !important;
  }

  .header__search .predictive-search__result-group:first-child .predictive-search__item {
    display: flex !important;
    align-items: center !important;
    padding: 11px 4px 11px 0 !important;
    text-decoration: none !important;
    color: #222 !important;
    font-size: 14px !important;
    transition: color 0.15s, padding-left 0.15s !important;
    background: none !important;
    gap: 8px !important;
  }

  .header__search .predictive-search__result-group:first-child .predictive-search__item:hover {
    color: #000 !important;
    padding-left: 6px !important;
  }

  .header__search .predictive-search__item-heading.predictive-search__item-query-result {
    font-size: 14px !important;
    margin: 0 !important;
    color: inherit !important;
  }

  /* ── PRODUCT ITEMS ── */
  .header__search .predictive-search__item--link-with-thumbnail {
    display: flex !important;
    align-items: center !important;
    gap: 14px !important;
    padding: 10px 0 !important;
    text-decoration: none !important;
    color: #222 !important;
    border-bottom: 1px solid #ececec !important;
    transition: opacity 0.15s !important;
    background: none !important;
  }

  .header__search .predictive-search__list-item:last-child .predictive-search__item--link-with-thumbnail {
    border-bottom: none !important;
  }

  .header__search .predictive-search__item--link-with-thumbnail:hover {
    opacity: 0.65 !important;
  }

  .header__search .predictive-search__image {
    width: 56px !important;
    height: 56px !important;
    min-width: 56px !important;
    object-fit: cover !important;
    border-radius: 10px !important;
    background: #ddd !important;
    display: block !important;
  }

  .header__search .predictive-search__item-content {
    display: flex !important;
    flex-direction: column !important;
    gap: 3px !important;
    min-width: 0 !important;
  }

  .header__search .predictive-search__item-content--centered {
    justify-content: center !important;
  }

  .header__search .predictive-search__item-heading {
    font-size: 14px !important;
    margin: 0 !important;
    color: #111 !important;
    line-height: 1.3 !important;
    white-space: normal !important;
  }

  .header__search .predictive-search__item-vendor {
    font-size: 11px !important;
    color: #aaa !important;
    text-transform: uppercase !important;
    letter-spacing: 0.06em !important;
    margin: 0 !important;
  }

  .header__search .predictive-search__pages-wrapper {
    margin-top: 1.6rem !important;
  }

  /* ── "SEARCH FOR X →" FOOTER ── */
  .header__search .predictive-search__search-for-button {
    border-top: 1px solid #e2e2e2 !important;
    padding-top: 1.2rem !important;
    margin-top: 1.2rem !important;
  }

  .header__search .predictive-search__item--term {
    background: none !important;
    border: none !important;
    cursor: pointer !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    width: 100% !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    color: #222 !important;
    padding: 6px 0 !important;
    font-family: inherit !important;
    text-align: left !important;
    transition: opacity 0.15s !important;
    box-shadow: none !important;
  }

  .header__search .predictive-search__item--term:hover {
    opacity: 0.6 !important;
  }

  .header__search .predictive-search__item--term svg {
    width: 16px !important;
    height: 16px !important;
    flex-shrink: 0 !important;
  }

  /* ── LOADING SPINNER ── */
  .header__search .predictive-search__loading-state {
    display: none !important;
    position: absolute !important;
    right: 16px !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
  }

  /* ============================================================
     MOBILE RESPONSIVE
  ============================================================ */
  @media screen and (max-width: 749px) {
    .header__search .search-modal__content {
      width: 96% !important;
      margin-top: 3.5rem !important;
      padding: 1.6rem 1.4rem 2rem !important;
      border-radius: 16px !important;
    }

    .header__search .search-modal__branding {
      gap: 1rem !important;
      padding-bottom: 1.2rem !important;
      margin-bottom: 1.2rem !important;
    }

    .header__search .search-modal__branding-logo img {
      max-height: 28px !important;
    }

    .header__search .search-modal__branding-shopname {
      font-size: 17px !important;
    }

    .header__search .search-modal__branding-welcome {
      font-size: 12px !important;
    }

    .header__search .search-modal__branding-tagline {
      font-size: 10px !important;
    }

    .header__search .search-modal__close-button.modal__close-button {
      top: 1.2rem !important;
      right: 1.2rem !important;
      width: 30px !important;
      height: 30px !important;
    }

    .header__search #predictive-search-results-groups-wrapper {
      grid-template-columns: 1fr !important;
      gap: 1.6rem 0 !important;
    }

    .header__search .predictive-search__result-group:last-child:not(:first-child) {
      border-left: none !important;
      border-top: 1px solid #e2e2e2 !important;
      padding-left: 0 !important;
      padding-top: 1.4rem !important;
    }

    .header__search .search-field-custom {
      height: 46px !important;
      padding-left: 16px !important;
    }
  }
</style>
