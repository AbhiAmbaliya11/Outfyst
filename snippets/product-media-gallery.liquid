{% comment %}
  PERFECTED: Fixed Main Image (Left) + Scrolling Images (Right)
  Mobile: Full-width centered swipe carousel — one image at a time.
{% endcomment %}

{%- liquid
  if section.settings.hide_variants and variant_images.size == product.media.size
    assign single_media_visible = true
  endif
  assign media_count = product.media.size
  assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media
-%}

<media-gallery
  id="MediaGallery-{{ section.id }}"
  role="region"
  class="product-media-container"
  aria-label="{{ 'products.product.media.gallery_viewer' | t }}"
>
  <div id="GalleryStatus-{{ section.id }}" class="visually-hidden" role="status"></div>
  
  <slider-component id="GalleryViewer-{{ section.id }}" class="slider-mobile-gutter">
    <ul
      id="Slider-Gallery-{{ section.id }}"
      class="product__media-list contains-media grid list-unstyled slider slider--mobile custom-media-grid"
      role="list"
    >
      {%- if featured_media != null -%}
        <li
          id="Slide-{{ section.id }}-{{ featured_media.id }}"
          class="product__media-item grid__item slider__slide is-active main-sticky-col"
          data-media-id="{{ section.id }}-{{ featured_media.id }}"
        >
          {% render 'product-thumbnail',
            media: featured_media,
            media_count: media_count,
            position: 1,
            desktop_layout: section.settings.gallery_layout,
            mobile_layout: section.settings.mobile_thumbnails,
            loop: section.settings.enable_video_looping,
            modal_id: section.id,
            xr_button: true,
            media_width: 0.5,
            lazy_load: false
          %}
        </li>
      {%- endif -%}

      {%- for media in product.media -%}
        {%- unless media.id == featured_media.id -%}
          <li
            id="Slide-{{ section.id }}-{{ media.id }}"
            class="product__media-item grid__item slider__slide secondary-scroll-col"
            data-media-id="{{ section.id }}-{{ media.id }}"
          >
            {% render 'product-thumbnail',
              media: media,
              media_count: media_count,
              position: forloop.index,
              desktop_layout: section.settings.gallery_layout,
              mobile_layout: section.settings.mobile_thumbnails,
              loop: section.settings.enable_video_looping,
              modal_id: section.id,
              xr_button: true,
              media_width: 0.5,
              lazy_load: true
            %}
          </li>
        {%- endunless -%}
      {%- endfor -%}
    </ul>

    {%- comment -%} Mobile dot indicators {%- endcomment -%}
    {%- if product.media.size > 1 -%}
      <div class="mobile-gallery-dots" id="MobileDots-{{ section.id }}">
        {%- for media in product.media -%}
          <button
            class="mobile-dot{% if forloop.first %} active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Go to image {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </slider-component>
</media-gallery>

<style>
/* ═══════════════════════════════════════════════
   DESKTOP LAYOUT — sticky left + scrolling right
═══════════════════════════════════════════════ */
@media screen and (min-width: 990px) {
  .custom-media-grid {
    display: grid !important;
    grid-template-columns: 1.5fr 1fr !important;
    overflow: visible !important;
    padding: 0 !important;
    margin: 0 !important;
    align-items: start !important;
    position: relative !important;
    gap: 0px;
  }

  .custom-media-grid .product__media-item {
    max-width: 100% !important;
    width: 100% !important;
  }

  /* LEFT: Main Image (Sticky) */
  .main-sticky-col {
    grid-column: 1 !important;
    grid-row: 1 / span 50 !important;
    position: sticky !important;
    top: 5vw !important;
    align-self: start !important;
    z-index: 2;
    overflow: hidden;
  }

  .main-sticky-col .product__media,
  .main-sticky-col img {
    height: 100vh !important;
    width: 100% !important;
    object-fit: cover !important;
    padding: 0px !important;
  }

  /* RIGHT: Scrolling Images */
  .secondary-scroll-col {
    grid-column: 2 !important;
    height: auto !important;
    position: relative !important;
  }

  .secondary-scroll-col img {
    height: auto !important;
    width: 100% !important;
    object-fit: contain !important;
  }

  /* Hide slider controls on desktop */
  .slider-buttons,
  .slider-button {
    display: none !important;
  }

  /* Hide mobile dots on desktop */
  .mobile-gallery-dots {
    display: none !important;
  }
}

/* ═══════════════════════════════════════════════
   MOBILE LAYOUT — full-width centered swipe carousel
═══════════════════════════════════════════════ */
@media screen and (max-width: 989px) {

  /* Wrapper: kill any side padding that causes bleed */
  .product-media-container {
    width: 100% !important;
    overflow: hidden !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .product-media-container .slider-mobile-gutter {
    padding: 0 !important;
    margin: 0 !important;
  }

  /* The scroll track */
  .custom-media-grid {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: nowrap !important;
    overflow-x: scroll !important;
    scroll-snap-type: x mandatory !important;
    -webkit-overflow-scrolling: touch !important;
    scrollbar-width: none !important;   /* Firefox */
    -ms-overflow-style: none !important; /* IE/Edge */
    padding: 0 !important;
    margin: 0 !important;
    gap: 0 !important;
    width: 100% !important;
  }

  /* Hide scrollbar in WebKit */
  .custom-media-grid::-webkit-scrollbar {
    display: none !important;
  }

  /* Each slide: exactly 100% wide, centered, snapped */
  .custom-media-grid .product__media-item {
    flex: 0 0 100% !important;
    width: 100% !important;
    min-width: 100% !important;
    max-width: 100% !important;
    scroll-snap-align: center !important;
    scroll-snap-stop: always !important;
    padding: 0 !important;
    margin: 0 !important;
    position: relative !important;
    overflow: hidden !important;
  }

  /* Image fills the slide, portrait crop */
  .custom-media-grid .product__media-item .product__media,
  .custom-media-grid .product__media-item img {
    width: 100% !important;
    height: 100vw !important;      /* square — change to e.g. 125vw for portrait */
    max-height: 100vw !important;
    object-fit: cover !important;
    object-position: center top !important;
    display: block !important;
    padding: 0 !important;
    margin: 0 auto !important;
  }

  /* Deferred media wrapper fix */
  .custom-media-grid .product__media-item deferred-media,
  .custom-media-grid .product__media-item .deferred-media {
    width: 100% !important;
    height: 100vw !important;
    display: block !important;
  }

  /* Override any theme sticky/position from desktop */
  .main-sticky-col,
  .secondary-scroll-col {
    position: relative !important;
    top: auto !important;
    grid-column: unset !important;
    grid-row: unset !important;
    align-self: auto !important;
  }

  /* Hide desktop slider controls */
  .slider-buttons,
  .slider-button {
    display: none !important;
  }

  /* ── Dot indicators ── */
  .mobile-gallery-dots {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    gap: 6px !important;
    padding: 10px 0 6px !important;
    width: 100% !important;
  }

  .mobile-dot {
    width: 7px !important;
    height: 7px !important;
    border-radius: 50% !important;
    background: rgba(0, 0, 0, 0.2) !important;
    border: none !important;
    padding: 0 !important;
    cursor: pointer !important;
    transition: background 0.2s, transform 0.2s !important;
    flex-shrink: 0 !important;
  }

  .mobile-dot.active {
    background: rgba(0, 0, 0, 0.75) !important;
    transform: scale(1.3) !important;
  }
}
</style>

<script>
/* Mobile dot indicator sync */
(function () {
  if (window.innerWidth >= 990) return;

  const gallery  = document.getElementById('Slider-Gallery-{{ section.id }}');
  const dotsWrap = document.getElementById('MobileDots-{{ section.id }}');
  if (!gallery || !dotsWrap) return;

  const dots  = Array.from(dotsWrap.querySelectorAll('.mobile-dot'));
  const items = Array.from(gallery.querySelectorAll('.product__media-item'));
  if (!dots.length || !items.length) return;

  function setActive(index) {
    dots.forEach(function (d, i) {
      d.classList.toggle('active', i === index);
    });
  }

  /* Scroll spy using IntersectionObserver */
  const observer = new IntersectionObserver(
    function (entries) {
      entries.forEach(function (entry) {
        if (entry.intersectionRatio >= 0.5) {
          const idx = items.indexOf(entry.target);
          if (idx !== -1) setActive(idx);
        }
      });
    },
    { root: gallery, threshold: 0.5 }
  );

  items.forEach(function (item) { observer.observe(item); });

  /* Dot click → scroll to slide */
  dots.forEach(function (dot, i) {
    dot.addEventListener('click', function () {
      const target = items[i];
      if (target) {
        gallery.scrollTo({ left: target.offsetLeft, behavior: 'smooth' });
      }
    });
  });
})();
</script>
